; bounds_check: c[i] = a[i] + b[i], only for i < n
; Tests if/endif predication with partial workgroup execution
; Memory layout: a at byte 0, b at byte 1024, c at byte 2048 (256 elements each)
; n is passed as a u32 at byte 3072

.kernel bounds_check
.registers 16
.workgroup_size 256, 1, 1

    mov_sr r0, sr_thread_id_x
    mov_imm r1, 4
    imul r2, r0, r1

    ; Load n from fixed memory location
    mov_imm r14, 3072
    device_load_u32 r15, r14

    ; if (thread_id < n)
    ucmp_lt p0, r0, r15
    if p0

    device_load_u32 r3, r2

    mov_imm r4, 1024
    iadd r5, r2, r4
    device_load_u32 r6, r5

    fadd r7, r3, r6

    mov_imm r8, 2048
    iadd r9, r2, r8
    device_store_u32 r9, r7

    endif
    halt
.end
