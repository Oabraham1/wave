    mov_imm r29, 0
    mov_imm r30, 0
    mov_imm r31, 0
    mov_imm r32, 0
    mov_imm r33, 0
    mov_imm r34, 0
    mov_imm r35, 0
    mov_imm r36, 0
    mov_imm r37, 0
    mov_imm r38, 0
    mov_imm r39, 0
    mov_imm r40, 0
    mov_imm r41, 0
    mov_imm r42, 0
    mov_imm r43, 0
    mov_imm r44, 0
    mov_imm r45, 0
    mov_imm r46, 0
    mov_imm r47, 0
    mov_imm r48, 0
    mov_imm r49, 0
    mov_imm r50, 0
    mov_imm r51, 0
    mov_imm r52, 0
    mov_imm r53, 0
    mov_imm r54, 0
    mov_imm r55, 0
    mov_imm r56, 0
    mov_imm r57, 0
    mov_imm r58, 0
    mov_imm r59, 0
    mov_imm r60, 0
    mov_imm r61, 0
    mov_imm r62, 0
    mov_imm r63, 0
    mov_imm r64, 0
    mov_imm r65, 0
    mov_imm r66, 0
    mov_imm r67, 0
    mov_imm r68, 0
    mov_imm r69, 0
    mov_imm r70, 0
    mov_imm r71, 0
    mov_imm r72, 0
    mov_imm r73, 0
    mov_imm r74, 0
    mov_imm r75, 0
    mov_imm r76, 0
    mov_imm r77, 0
    mov_imm r78, 0
    mov_imm r79, 0

    mov_imm r15, 0

    mov_imm r89, 16384
    local_load_u32 r11, r89

    mov_imm r89, 7
    and r12, r9, r89
    mov_imm r89, 3
    shr r13, r9, r89

    mov_sr r89, sr_workgroup_id_y
    mov_imm r90, 128
    imul r89, r89, r90
    iadd r14, r89, r13

