            local_store_u32 r14, r92

            iadd r95, r95, r90
            iadd r14, r14, r91
            device_load_u32 r92, r95
            local_store_u32 r14, r92

            mov_imm r89, 16388
            local_load_u32 r11, r89
            mov_imm r89, 16396
            local_load_u32 r12, r89

            mov_imm r89, 127
            and r13, r9, r89
            mov_imm r89, 7
            shr r14, r9, r89

            mov_imm r89, 8
            iadd r89, r10, r89
            iadd r89, r89, r14
            mov_sr r90, sr_workgroup_id_x
            mov_imm r91, 128
            imul r90, r90, r91
            iadd r90, r90, r13
            imul r89, r89, r12
            iadd r89, r89, r90

            mov_imm r91, 4
            imul r89, r89, r91
            iadd r89, r89, r11

            mov_imm r90, 2
            imul r90, r12, r90
            mov_imm r91, 4
            imul r90, r90, r91

            mov_imm r91, 4
            imul r14, r9, r91
            mov_imm r91, 4096
            iadd r14, r14, r91
            iadd r14, r14, r94
            mov_imm r91, 1024

            device_load_u32 r92, r89
            local_store_u32 r14, r92

            iadd r89, r89, r90
            iadd r14, r14, r91
            device_load_u32 r92, r89
            local_store_u32 r14, r92

            iadd r89, r89, r90
            iadd r14, r14, r91
            device_load_u32 r92, r89
            local_store_u32 r14, r92

            iadd r89, r89, r90
            iadd r14, r14, r91
            device_load_u32 r92, r89
            local_store_u32 r14, r92

        endif

        mov_imm r89, 256
        imul r12, r8, r89
        iadd r12, r12, r15

        mov_imm r89, 32
        imul r13, r7, r89
        mov_imm r89, 4096
        iadd r13, r13, r89
        iadd r13, r13, r15

        mov_imm r14, 32
        iadd r14, r12, r14

        loop
            icmp_ge p0, r12, r14
            break p0

            mov_imm r11, 4
            mov r89, r13
            local_load_u32 r80, r89
            iadd r89, r89, r11
            local_load_u32 r81, r89
            iadd r89, r89, r11
            local_load_u32 r82, r89
            iadd r89, r89, r11
            local_load_u32 r83, r89
            iadd r89, r89, r11
            local_load_u32 r84, r89
            iadd r89, r89, r11
            local_load_u32 r85, r89
            iadd r89, r89, r11
            local_load_u32 r86, r89
            iadd r89, r89, r11
            local_load_u32 r87, r89

            local_load_u32 r88, r12
            fma r16, r88, r80, r16
            fma r17, r88, r81, r17
            fma r18, r88, r82, r18
            fma r19, r88, r83, r19
            fma r20, r88, r84, r20
            fma r21, r88, r85, r21
            fma r22, r88, r86, r22
            fma r23, r88, r87, r23

            mov_imm r89, 32
            iadd r89, r12, r89
            local_load_u32 r88, r89
            fma r24, r88, r80, r24
            fma r25, r88, r81, r25
            fma r26, r88, r82, r26
            fma r27, r88, r83, r27
            fma r28, r88, r84, r28
            fma r29, r88, r85, r29
            fma r30, r88, r86, r30
