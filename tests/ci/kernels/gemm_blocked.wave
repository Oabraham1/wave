    iadd r14, r89, r90

    mov_imm r90, 4
    imul r15, r12, r90

    imul r89, r13, r12
    iadd r89, r89, r14
    mov_imm r90, 4
    imul r89, r89, r90
    iadd r89, r89, r11

    mov_imm r90, 4

    device_store_u32 r89, r16
    iadd r91, r89, r90
    device_store_u32 r91, r17
    iadd r91, r91, r90
