    device_load_u32 r92, r89
    local_store_u32 r14, r92

    iadd r89, r89, r90
    iadd r14, r14, r91
    device_load_u32 r92, r89
    local_store_u32 r14, r92

    iadd r89, r89, r90
    iadd r14, r14, r91
    device_load_u32 r92, r89
    local_store_u32 r14, r92

