            local_load_u32 r88, r89
            fma r32, r88, r80, r32
            fma r33, r88, r81, r33
            fma r34, r88, r82, r34
            fma r35, r88, r83, r35
            fma r36, r88, r84, r36
            fma r37, r88, r85, r37
            fma r38, r88, r86, r38
            fma r39, r88, r87, r39

            mov_imm r89, 96
            iadd r89, r12, r89
            local_load_u32 r88, r89
            fma r40, r88, r80, r40
            fma r41, r88, r81, r41
            fma r42, r88, r82, r42
            fma r43, r88, r83, r43
            fma r44, r88, r84, r44
            fma r45, r88, r85, r45
            fma r46, r88, r86, r46
            fma r47, r88, r87, r47

            mov_imm r89, 128
            iadd r89, r12, r89
            local_load_u32 r88, r89
            fma r48, r88, r80, r48
            fma r49, r88, r81, r49
            fma r50, r88, r82, r50
            fma r51, r88, r83, r51
            fma r52, r88, r84, r52
            fma r53, r88, r85, r53
            fma r54, r88, r86, r54
            fma r55, r88, r87, r55

            mov_imm r89, 160
            iadd r89, r12, r89
            local_load_u32 r88, r89
            fma r56, r88, r80, r56
            fma r57, r88, r81, r57
            fma r58, r88, r82, r58
            fma r59, r88, r83, r59
            fma r60, r88, r84, r60
            fma r61, r88, r85, r61
            fma r62, r88, r86, r62
            fma r63, r88, r87, r63

