    imul r14, r9, r91

    mov_imm r91, 512

    device_load_u16 r92, r89
    local_store_u16 r14, r92

    iadd r89, r89, r90
    iadd r14, r14, r91
    device_load_u16 r92, r89
    local_store_u16 r14, r92

    iadd r89, r89, r90
    iadd r14, r14, r91
    device_load_u16 r92, r89
    local_store_u16 r14, r92

    iadd r89, r89, r90
    iadd r14, r14, r91
    device_load_u16 r92, r89
    local_store_u16 r14, r92

    mov_imm r89, 8196
    local_load_u32 r11, r89
    mov_imm r89, 8204
    local_load_u32 r12, r89

    mov_imm r89, 127
    and r13, r9, r89
    mov_imm r89, 7
    shr r14, r9, r89

    mov r89, r14
    mov_sr r90, sr_workgroup_id_x
    mov_imm r91, 128
    imul r90, r90, r91
    iadd r90, r90, r13
    imul r89, r89, r12
    iadd r89, r89, r90

