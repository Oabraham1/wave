            local_store_u16 r14, r92

            iadd r95, r95, r90
            iadd r14, r14, r91
            device_load_u16 r92, r95
            local_store_u16 r14, r92

            mov_imm r89, 8196
            local_load_u32 r11, r89
            mov_imm r89, 8204
            local_load_u32 r12, r89

            mov_imm r89, 127
            and r13, r9, r89
            mov_imm r89, 7
