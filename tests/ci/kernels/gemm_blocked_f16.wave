            local_load_u16 r88, r89
            cvt_f32_f16 r88, r88
            fma r32, r88, r80, r32
            fma r33, r88, r81, r33
            fma r34, r88, r82, r34
            fma r35, r88, r83, r35
            fma r36, r88, r84, r36
            fma r37, r88, r85, r37
            fma r38, r88, r86, r38
            fma r39, r88, r87, r39

            mov_imm r89, 48
            iadd r89, r12, r89
            local_load_u16 r88, r89
            cvt_f32_f16 r88, r88
            fma r40, r88, r80, r40
            fma r41, r88, r81, r41
            fma r42, r88, r82, r42
            fma r43, r88, r83, r43
            fma r44, r88, r84, r44
