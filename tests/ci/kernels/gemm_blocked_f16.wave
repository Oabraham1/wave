; SPDX-License-Identifier: Apache-2.0
;
; Mixed-precision GEMM: F16 inputs, F32 accumulation, F16 output.
;
; Computes C = A * B for row-major f16 matrices using 8x8 register blocking
; with 128x128 output tiles and 8-deep k-dimension slices. Loads A and B as
; f16, converts to f32 for FMA accumulation, then converts back to f16 for
; output. Each thread in a 16x16 workgroup computes an 8x8 sub-tile of C
; entirely in registers. Uses double buffering to overlap prefetching of
; tile N+1 into one shared memory buffer while computing on tile N from
; the other buffer. Requires M, N to be multiples of 128 and K to be a
; multiple of 8.
;
; Register arguments via --set-reg:
;   r0 = A device memory byte offset
;   r1 = B device memory byte offset
;   r2 = C device memory byte offset
;   r3 = M (rows of A and C, unused but reserved)
;   r4 = N (cols of B and C)
;   r5 = K (cols of A, rows of B)
;
; Shared memory layout (8208 bytes):
;   [0..2047]     A buf0: 128 rows x 8 cols, row-major f16
;   [2048..4095]  B buf0: 8 rows x 128 cols, row-major f16
;   [4096..6143]  A buf1: 128 rows x 8 cols, row-major f16
;   [6144..8191]  B buf1: 8 rows x 128 cols, row-major f16
;   [8192..8207]  saved parameters: A_base, B_base, C_base, N_dim
;
; Register allocation:
;   r0-r5    initial kernel arguments
;   r6       K_dim (saved constant)
;   r7       tid_x (0..15, constant)
;   r8       tid_y (0..15, constant)
;   r9       linear_tid (tid_y * 16 + tid_x, 0..255, constant)
;   r10      k_tile outer loop counter
;   r11-r14  temps for address computation
;   r15      buf_read_offset (0 or 4096, swapped each iteration)
;   r16-r79  accumulators (8x8 = 64 values, f32)
;   r80-r87  B values during inner compute
;   r88      A value during inner compute
;   r89-r95  additional temps

.kernel gemm_register_blocked_8x8_f16
.registers 96
.workgroup_size 16, 16, 1
.local_memory 8208

    mov r6, r5

    mov_imm r11, 8192
    local_store_u32 r11, r0
    mov_imm r11, 8196
    local_store_u32 r11, r1
    mov_imm r11, 8200
    local_store_u32 r11, r2
    mov_imm r11, 8204
    local_store_u32 r11, r4

    mov_sr r7, sr_thread_id_x
    mov_sr r8, sr_thread_id_y
    mov_imm r11, 16
    imul r9, r8, r11
    iadd r9, r9, r7

    mov_imm r16, 0
